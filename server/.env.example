# 应用配置
PORT=8000
LOG_LEVEL=INFO

# 后端配置文件路径
BACKENDS_CONFIG_PATH=./config/backends.json

# 健康检查间隔(秒)
HEALTH_CHECK_INTERVAL=30

# 请求超时
REQUEST_TIMEOUT=30
HEALTH_CHECK_TIMEOUT=5

# 配置热加载（修改 backends.json 后自动生效，无需重启）
CONFIG_RELOAD_WATCH=true         # 是否启用文件监听（默认 true）
CONFIG_RELOAD_INTERVAL=2.0       # 文件 mtime 轮询间隔（秒）

# 并发和连接池配置
MAX_CONNECTIONS=100          # httpx 连接池最大连接数
MAX_KEEPALIVE_CONNECTIONS=20 # 保活连接数

# 后端API密钥认证
BACKEND_API_KEY=xxxx
# 密钥传递方式: Authorization (在请求头中) 或其他方式
BACKEND_AUTH_MODE=Authorization
